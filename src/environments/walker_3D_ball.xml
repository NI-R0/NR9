<mujoco model="walker_3D_ball">
  <include file="./common/visual.xml"/>
  <include file="./common/skybox.xml"/>
  <include file="./common/materials.xml"/>

  <option timestep="0.0025" integrator="RK4">
    <flag contact="enable"/>
  </option>

  <statistic extent="2" center="0 0 1"/>

  <default>
    <joint damping=".1" armature="0.01" limited="true" solimplimit="0 .99 .01"/>
    <geom contype="1" conaffinity="0" friction=".7 .1 .1"/>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
    <site size="0.01"/>
    <default class="walker">
      <geom material="self" type="capsule"/>
    </default>
    <default class="touch">
      <site type="capsule" rgba="0 0 1 .3" group="3"/>
    </default>
  </default>

  <worldbody>
    <geom name="floor" type="plane" conaffinity="1" pos="0 0 0" size="100 100 .2" material="grid" zaxis="0 0 1"/>
    <body name="torso" pos="0 0 1.3" childclass="walker">
      <light name="light" pos="0 0 2" mode="trackcom"/>
      <camera name="side" pos="0 -3 1" mode="trackcom"/>
      <camera name="back" pos="-3 0 1" mode="trackcom"/>
      <freejoint name="root"/>
      <geom name="torso" size="0.07 0.3"/>
      <site name="torso_touch" class="touch" pos="0 0 0" size="0.08 0.32"/>
      <body name="right_thigh" pos="0 -.05 -0.3">
        <joint name="right_hip_yaw" axis="0 0 1" range="-45 45"/>
        <joint name="right_hip_roll" axis="1 0 0" range="-25 45"/>
        <joint name="right_hip_pitch" axis="0 1 0" range="-35 80"/>
        <geom name="right_thigh" pos="0 0 -0.225" size="0.05 0.225"/>
        <site name="right_thigh_touch" class="touch" pos="0 0 -0.225" size="0.055 0.225"/>
        <body name="right_leg" pos="0 0 -0.7">
          <joint name="right_knee" pos="0 0 0.25" axis="0 -1 0" range="-150 0"/>
          <geom name="right_leg" size="0.04 0.25"/>
          <site name="right_leg_touch" class="touch" pos="0 0 -0.12" size="0.045 0.25"/>
          <body name="right_foot" pos="0.06 0 -0.25">
            <joint name="right_ankle" pos="-0.06 0 0" axis="0 -1 0" range="-45 45"/>
            <geom name="right_foot" zaxis="1 0 0" size="0.05 0.1"/>
            <site name="right_foot_touch" class="touch" pos="0 0 0" size="0.055 0.1" zaxis="1 0 0"/>
          </body>
        </body>
      </body>
      <body name="left_thigh" pos="0 .05 -0.3">
        <joint name="left_hip_yaw" axis="0 0 1" range="-45 45"/>
        <joint name="left_hip_roll" axis="1 0 0" range="-25 45"/>
        <joint name="left_hip_pitch" axis="0 1 0" range="-35 80"/>
        <geom name="left_thigh" pos="0 0 -0.225" size="0.05 0.225"/>
        <site name="left_thigh_touch" class="touch" pos="0 0 -0.225" size="0.055 0.225"/>
        <body name="left_leg" pos="0 0 -0.7">
          <joint name="left_knee" pos="0 0 0.25" axis="0 -1 0" range="-150 0"/>
          <geom name="left_leg" size="0.04 0.25"/>
          <site name="left_leg_touch" class="touch" pos="0 0 -0.12" size="0.045 0.25"/>
          <body name="left_foot" pos="0.06 0 -0.25">
            <joint name="left_ankle" pos="-0.06 0 0" axis="0 -1 0" range="-45 45"/>
            <geom name="left_foot" zaxis="1 0 0" size="0.05 0.1"/>
            <site name="left_foot_touch" class="touch" pos="0 0 0" size="0.055 0.1" zaxis="1 0 0"/>
          </body>
        </body>
      </body>
    </body>

    <!-- Ball to kick (free-floating) -->
    <body name="ball" pos="1.5 0 0.15">
      <freejoint name="ball_joint"/>
      <geom name="ball" type="sphere" size="0.2" rgba="0.8 0.2 0.2 1" mass="0.01"
            contype="1" conaffinity="1"/>
    </body>

    <!-- Target zone (mocap body: visual-only marker, repositioned dynamically).
         The geom size is set programmatically by the task (curriculum). -->
    <body name="target" pos="3 0 0.1" mocap="true">
      <geom name="target_zone" type="box" size="1 1 0.05" rgba="0.1 0.8 0.1 0.3"
            contype="0" conaffinity="0"/>
    </body>
  </worldbody>

  <sensor>
    <subtreelinvel name="torso_subtreelinvel" body="torso"/>

    <touch name="torso_touch"          site="torso_touch"/>
    <touch name="right_thigh_touch"    site="right_thigh_touch"/>
    <touch name="left_thigh_touch"     site="left_thigh_touch"/>
    <touch name="right_leg_touch"      site="right_leg_touch"/>
    <touch name="left_leg_touch"       site="left_leg_touch"/>
    <touch name="right_foot_touch"     site="right_foot_touch"/>
    <touch name="left_foot_touch"      site="left_foot_touch"/>
  </sensor>

  <actuator>
    <motor name="right_hip_yaw" joint="right_hip_yaw" gear="50"/>
    <motor name="right_hip_roll" joint="right_hip_roll" gear="50"/>
    <motor name="right_hip_pitch" joint="right_hip_pitch" gear="100"/>
    <motor name="right_knee" joint="right_knee" gear="50"/>
    <motor name="right_ankle" joint="right_ankle" gear="20"/>
    <motor name="left_hip_yaw" joint="left_hip_yaw" gear="50"/>
    <motor name="left_hip_roll" joint="left_hip_roll" gear="50"/>
    <motor name="left_hip_pitch" joint="left_hip_pitch" gear="100"/>
    <motor name="left_knee" joint="left_knee" gear="50"/>
    <motor name="left_ankle" joint="left_ankle" gear="20"/>
  </actuator>
</mujoco>
